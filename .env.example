# Local development only. Never use these credentials in shared or production environments.
NODE_ENV=development
APP_ENV=local
APP_VERSION=0.0.3
LOG_LEVEL=info
API_HOST=127.0.0.1
API_PORT=3000
WEB_PORT=5173
WEB_API_BASE_URL=http://127.0.0.1:3000
VITE_APP_VERSION=0.0.3
VITE_APP_ENV=local
VITE_API_BASE_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql://gemwatch_local:gemwatch_local_only@127.0.0.1:5432/gemwatch_local
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
OTEL_ENABLED=false
OTEL_SERVICE_NAME=gemwatch-api
OTEL_EXPORTER_OTLP_ENDPOINT=
LIVE_TRADING_ENABLED=false
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
