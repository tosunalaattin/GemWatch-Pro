{
  "name": "gemwatch-pro",
  "version": "0.0.4",
  "private": true,
  "description": "GemWatch Pro development platform",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @gemwatch/web dev",
    "dev:api": "pnpm --filter @gemwatch/api dev",
    "dev:worker": "pnpm --filter @gemwatch/worker dev",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run build --filter=@gemwatch/config --filter=@gemwatch/contracts --filter=@gemwatch/domain --filter=@gemwatch/observability --filter=@gemwatch/testing && eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "pnpm test:unit",
    "test:unit": "turbo run test:unit",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test --config tests/end-to-end/playwright.config.ts",
    "test:coverage": "turbo run test:coverage",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build && pnpm check:docs && pnpm check:workspace",
    "check:docs": "node infrastructure/scripts/check-docs.mjs",
    "check:env": "node infrastructure/scripts/check-env.mjs",
    "check:workspace": "node infrastructure/scripts/verify-workspace.mjs",
    "security:audit": "pnpm audit --audit-level high",
    "security:secrets": "node infrastructure/scripts/scan-secrets.mjs",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs --tail 100",
    "infra:reset": "node infrastructure/scripts/reset-infrastructure.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "24.13.3",
    "eslint": "9.39.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.4.0",
    "prettier": "3.9.5",
    "testcontainers": "12.0.4",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
